# ---------------------------------------------------------------------------
# Copy this file to  .streamlit/secrets.toml  and fill in what you need.
# NEVER commit the real secrets.toml (it is in .gitignore).
# On Streamlit Community Cloud, paste these into the app's "Secrets" UI instead.
# ---------------------------------------------------------------------------

# Data store: "false" = local SQLite (zero setup, default).  "true" = Google Sheets.
USE_SHEETS = "false"

# Optional dashboard passcode. If set, open the dashboard with  ?key=YOUR_KEY
ADMIN_KEY = ""

# Allow the same person to check in more than once. "false" = block duplicates.
ALLOW_DUPLICATES = "false"

# Timezone used for timestamps shown on screen.
TIMEZONE = "Asia/Ho_Chi_Minh"

# ----------------------- Only needed when USE_SHEETS = "true" ----------------
SHEET_NAME = "qr-unipass-attendance"

# Paste your Google service-account JSON here (keys below are placeholders):
# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "qr-unipass@your-project-id.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
